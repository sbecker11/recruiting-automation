# Copy to `.env` (same directory) and adjust. `.env` is git-ignored.
# Purely local schedule config — no secrets live here.

# How many hours the automation runs unattended before it self-halts and
# waits for a "triage" login (see README's "state/expiry_epoch" entry).
# A CLI arg to install.sh (e.g. `./install.sh 72`) always overrides this.
# Falls back to 48 if this file is absent or the value is unset/blank.
WINDOW_HOURS=48
